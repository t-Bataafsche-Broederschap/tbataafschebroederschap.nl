    <item>
      <title>Wereldbevolking</title>
      <link>https://tbataafschebroederschap.nl/projects/wereldbevolking/</link>
      <pubDate>Mon, 06 Apr 2026 20:17:25 +0200</pubDate>
      <guid>https://tbataafschebroederschap.nl/projects/wereldbevolking/</guid>
      <description>&lt;link rel=&#34;stylesheet&#34; href=&#34;https://tbataafschebroederschap.nl/styles/project-theme.css&#34; /&gt;&#xA;&lt;link rel=&#34;stylesheet&#34; href=&#34;styles.css&#34; /&gt;&#xA;&#xA;&lt;article class=&#34;project-page project-page--wereldbevolking&#34;&gt;&#xA;&#x9;&lt;section class=&#34;project-experience world-population-experience&#34;&gt;&#xA;&#x9;&#x9;&lt;section class=&#34;project-panel world-population-panel&#34;&gt;&#xA;&#x9;&#x9;&#x9;&lt;h2&gt;Alle landen door de tijd&lt;/h2&gt;&#xA;&#x9;&#x9;&#x9;&lt;p&gt;Deze grafiek tekent elk land en afhankelijk gebied in de dataset over de volledige historische en geraamde tijdlijn. Alle reeksen blijven op de achtergrond zichtbaar; gemarkeerde landen worden bovenop getekend zodat de grafiek leesbaar blijft.&lt;/p&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;project-toolbar world-population-toolbar&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;div class=&#34;world-population-metric&#34; aria-label=&#34;Maatstaf&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button is-active&#34; data-world-population-metric=&#34;population&#34; type=&#34;button&#34;&gt;Bevolking&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button&#34; data-world-population-metric=&#34;net-migration-share&#34; type=&#34;button&#34;&gt;Nettomigratie als percentage&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;div class=&#34;world-population-scale&#34; aria-label=&#34;Schaalmodus&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button is-active&#34; data-world-population-scale=&#34;log&#34; type=&#34;button&#34;&gt;Logaritmische schaal&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button&#34; data-world-population-scale=&#34;linear&#34; type=&#34;button&#34;&gt;Lineaire schaal&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;label class=&#34;world-population-visibility&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;input id=&#34;world-population-show-background&#34; type=&#34;checkbox&#34; checked /&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;Toon niet-geselecteerde landen&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/label&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;label class=&#34;world-population-comparison&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;input id=&#34;world-population-show-no-migration&#34; type=&#34;checkbox&#34; /&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;Vergelijk actief land zonder nettomigratie&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/label&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button&#34; id=&#34;world-population-reset&#34; type=&#34;button&#34;&gt;Wis markeringen&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;world-population-continents&#34; id=&#34;world-population-continents&#34; aria-label=&#34;Markeer werelddelen&#34;&gt;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;world-population-highlight&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;label class=&#34;world-population-field&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;Markeer land&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;input id=&#34;world-population-highlight&#34; list=&#34;world-population-country-list&#34; placeholder=&#34;Nederland, India, Nigeria...&#34; /&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/label&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;label class=&#34;world-population-slider&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;Buren aan elke kant: &lt;strong id=&#34;world-population-neighbor-count&#34;&gt;0&lt;/strong&gt;&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;input id=&#34;world-population-neighbor-range&#34; type=&#34;range&#34; min=&#34;0&#34; max=&#34;25&#34; step=&#34;1&#34; value=&#34;0&#34; /&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/label&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;button class=&#34;button&#34; id=&#34;world-population-add-highlight&#34; type=&#34;button&#34;&gt;Voeg markering toe&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;datalist id=&#34;world-population-country-list&#34;&gt;&lt;/datalist&gt;&#xA;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;world-population-legend&#34; id=&#34;world-population-legend&#34; aria-label=&#34;Gemarkeerde landen&#34;&gt;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;p class=&#34;world-population-status&#34; id=&#34;world-population-status&#34;&gt;Grafiekdata laden...&lt;/p&gt;</description>
