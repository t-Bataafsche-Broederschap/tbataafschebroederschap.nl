      <guid>https://tbataafschebroederschap.nl/projects/eu-begrotingsstromenkaart/</guid>
      <description>&lt;link rel=&#34;stylesheet&#34; href=&#34;https://tbataafschebroederschap.nl/styles/project-theme.css&#34; /&gt;&#xA;&lt;link rel=&#34;stylesheet&#34; href=&#34;styles.css&#34; /&gt;&#xA;&#xA;&lt;article class=&#34;project-page project-page--eu-begrotingsstromenkaart&#34;&gt;&#xA;&#x9;&lt;section class=&#34;project-experience app&#34;&gt;&#xA;&#x9;&#x9;&lt;section class=&#34;project-canvas-stage&#34;&gt;&#xA;&#x9;&#x9;&#x9;&lt;canvas id=&#34;map&#34; aria-label=&#34;Geanimeerde kaart van begrotingsstromen van de Europese Unie&#34;&gt;&lt;/canvas&gt;&#xA;&#x9;&#x9;&#x9;&lt;div id=&#34;countryTooltip&#34; class=&#34;country-tooltip&#34; role=&#34;status&#34; aria-live=&#34;polite&#34; hidden&gt;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;hud&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;div&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;p class=&#34;eyebrow&#34;&gt;Netto begrotingssaldo van de Europese Unie&lt;/p&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;h1 id=&#34;yearLabel&#34;&gt;2000&lt;/h1&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;div class=&#34;legend&#34; aria-hidden=&#34;true&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;&lt;i class=&#34;out&#34;&gt;&lt;/i&gt; netto betaler&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;span&gt;&lt;i class=&#34;in&#34;&gt;&lt;/i&gt; netto ontvanger&lt;/span&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#x9;&#x9;&lt;/section&gt;&#xA;&#xA;&#x9;&#x9;&lt;aside class=&#34;project-toolbar&#34;&gt;&#xA;&#x9;&#x9;&#x9;&lt;div class=&#34;project-toolbar__row&#34;&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;button id=&#34;play&#34; type=&#34;button&#34;&gt;Afspelen&lt;/button&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;label&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;Jaar&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;input id=&#34;year&#34; type=&#34;range&#34; min=&#34;2000&#34; max=&#34;2024&#34; value=&#34;2000&#34; step=&#34;1&#34; /&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&lt;/label&gt;&#xA;&#x9;&#x9;&#x9;&lt;/div&gt;&#xA;&#