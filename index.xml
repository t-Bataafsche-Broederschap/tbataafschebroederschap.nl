c=&#34;https://cdn.jsdelivr.net/npm/topojson-client@3&#34;&gt;&lt;/script&gt;&#xA;&lt;script type=&#34;module&#34; src=&#34;app.js&#34;&gt;&lt;/script&gt;</description>
